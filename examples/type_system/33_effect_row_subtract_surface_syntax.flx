// Surface syntax for effect rows with subtraction.

effect Console {
    print: String -> ()
}

fn run_with_row(f: (() -> Int with IO + Console - Console)) -> Int with IO + Console - Console {
    f()
}

fn io_only() -> Int with IO {
    print("io-only")
    10
}

fn main() with IO {
    print(to_string(run_with_row(io_only)))
}
