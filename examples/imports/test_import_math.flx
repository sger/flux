// Run with: cargo run -- --root examples examples/imports/test_import_math.flx

import Modules.Math as Math

// Using alias (Math instead of Modules.Math)
// See test_import_math_qualified.flx for fully qualified example

fn main() with IO {
    // Basic functions
    print(Math.square(5))
    print(Math.cube(3))

    // Forward reference examples: quadruple and triple use double (defined after them)
    print(Math.double(5))
    print(Math.triple(5))
    print(Math.quadruple(3))

    // Mutual recursion: isEven and isOdd call each other
    print(Math.isEven(10))
    print(Math.isOdd(10))
    print(Math.isEven(7))
    print(Math.isOdd(7))

    // print(Math._private_function()) // should error (private)
    // square(5)                        // should error (no leak)
}
