// Tests for list comprehensions: basic, with guards, multiple generators.

// --- basic comprehension ---

fn test_comprehension_basic() {
    let xs = list(1, 2, 3)
    let result = [x * 2 | x <- xs]
    assert_eq(len(result), 3)
    assert_eq(result[0], Some(2))
    assert_eq(result[1], Some(4))
    assert_eq(result[2], Some(6))
}

fn test_comprehension_identity() {
    let xs = list(10, 20, 30)
    let result = [x | x <- xs]
    assert_eq(len(result), 3)
    assert_eq(result[0], Some(10))
    assert_eq(result[1], Some(20))
    assert_eq(result[2], Some(30))
}

// --- comprehension with guard ---

fn test_comprehension_filter() {
    let xs = list(1, 2, 3, 4, 5)
    let result = [x | x <- xs, x > 3]
    assert_eq(len(result), 2)
    assert_eq(result[0], Some(4))
    assert_eq(result[1], Some(5))
}

fn test_comprehension_even_numbers() {
    let xs = list(1, 2, 3, 4, 5, 6)
    let result = [x | x <- xs, x % 2 == 0]
    assert_eq(len(result), 3)
    assert_eq(result[0], Some(2))
    assert_eq(result[1], Some(4))
    assert_eq(result[2], Some(6))
}

fn test_comprehension_transform_and_filter() {
    let xs = list(1, 2, 3, 4, 5)
    let result = [x * 10 | x <- xs, x > 2]
    assert_eq(len(result), 3)
    assert_eq(result[0], Some(30))
    assert_eq(result[1], Some(40))
    assert_eq(result[2], Some(50))
}

// --- multiple generators ---

fn test_comprehension_two_generators() {
    let xs = list(1, 2)
    let ys = list(10, 20)
    let result = [x + y | x <- xs, y <- ys]
    assert_eq(len(result), 4)
    assert_eq(result[0], Some(11))
    assert_eq(result[1], Some(21))
    assert_eq(result[2], Some(12))
    assert_eq(result[3], Some(22))
}

fn test_comprehension_two_generators_with_guard() {
    let xs = list(1, 2, 3)
    let ys = list(1, 2, 3)
    let result = [(x, y) | x <- xs, y <- ys, x + y == 4]
    assert_eq(len(result), 3)
    assert_eq(result[0], Some((1, 3)))
    assert_eq(result[1], Some((2, 2)))
    assert_eq(result[2], Some((3, 1)))
}

// --- comprehension with expressions ---

fn test_comprehension_string_transform() {
    let names = list("a", "b", "c")
    let result = [name + "!" | name <- names]
    assert_eq(len(result), 3)
    assert_eq(result[0], Some("a!"))
    assert_eq(result[1], Some("b!"))
    assert_eq(result[2], Some("c!"))
}

fn test_comprehension_tuple_construction() {
    let xs = list(1, 2, 3)
    let result = [(x, x * x) | x <- xs]
    assert_eq(len(result), 3)
    assert_eq(result[0], Some((1, 1)))
    assert_eq(result[1], Some((2, 4)))
    assert_eq(result[2], Some((3, 9)))
}

// --- empty results ---

fn test_comprehension_empty_source() {
    let result = [x * 2 | x <- []]
    assert_eq(len(result), 0)
}

fn test_comprehension_all_filtered() {
    let xs = list(1, 2, 3)
    let result = [x | x <- xs, x > 100]
    assert_eq(len(result), 0)
}
