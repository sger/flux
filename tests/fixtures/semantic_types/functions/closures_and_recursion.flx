fn make_adder(base) {
    fn(x) { base + x }
}

fn fact(n) {
    if n == 0 { 1 } else { n * fact(n - 1) }
}

fn evenish(n) {
    if n == 0 { true } else { oddish(n - 1) }
}

fn oddish(n) {
    if n == 0 { false } else { evenish(n - 1) }
}

fn main() with IO {
    let add10 = make_adder(10)
    print(add10(5))
    print(fact(5))
    print(evenish(4))
}
