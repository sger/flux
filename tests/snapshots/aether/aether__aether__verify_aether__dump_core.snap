letrec my_map =
λxs, f.
    case xs of
      ::(h, t) →
        let %t1 = aether_call[owned] f(h)
        let %t2 = aether_call[owned, borrowed] my_map(t, f)
        reuse xs ::(%t1, %t2)
      _ →
        []

letrec option_map =
λopt, f.
    case opt of
      Some(x) →
        let %t3 = aether_call[owned] f(x)
        reuse opt Some(%t3)
      _ →
        None

letrec set_black =
λt.
    case t of
      Node(_, left, key, right) →
        reuse t Node(Black, left, key, right) @mask=0b1
      _ →
        t

letrec my_len =
λxs.
    case xs of
      ::(_, t) →
        let %t4 = aether_call[borrowed] my_len(t)
        IAdd(1, %t4)
      _ →
        0

letrec my_filter =
λxs, f.
    case xs of
      ::(h, t) →
        let %t5 = aether_call[owned] f(h)
        case %t5 of
          true →
            let %t6 = aether_call[owned, borrowed] my_filter(t, f)
            reuse xs ::(h, %t6) @mask=0b10
          _ →
            drop xs
            aether_call[owned, borrowed] my_filter(t, f)
      _ →
        []

letrec my_sum =
λxs.
    case xs of
      ::(h, t) →
        let %t7 = aether_call[borrowed] my_sum(t)
        IAdd(h, %t7)
      _ →
        0

