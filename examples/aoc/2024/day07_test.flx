// parity-expected-stdout-begin
// parity-expected-stdout-end

import Day07Solver as Day07

// Sample input from the problem description
fn sample_lines() {
    [|
        "190: 10 19",
        "3267: 81 40 27",
        "83: 17 5",
        "156: 15 6",
        "7290: 6 8 6 15",
        "161011: 16 10 13",
        "192: 17 8 14",
        "21037: 9 7 18 13",
        "292: 11 6 16 20",
    |]
}

// Part A: sum of valid test values = 3749
fn test_day07_part_a_sample() {
    assert_eq(Day07.day07a(sample_lines()), 3749)
}

// Part B: with concatenation operator, sum = 11387
fn test_day07_part_b_sample() {
    assert_eq(Day07.day07b(sample_lines()), 11387)
}

// Single equation that works with multiply
fn test_day07_single_multiply() {
    assert_eq(Day07.day07a([|"190: 10 19"|]), 190)
}

// Single equation that works with add
fn test_day07_single_add() {
    assert_eq(Day07.day07a([|"29: 10 19"|]), 29)
}

// Single equation that doesn't work
fn test_day07_impossible() {
    assert_eq(Day07.day07a([|"83: 17 5"|]), 0)
}

// Two numbers only - both operators
fn test_day07_two_numbers() {
    // 15 = 10 + 5 (works)
    assert_eq(Day07.day07a([|"15: 10 5"|]), 15)
    // 50 = 10 * 5 (works)
    assert_eq(Day07.day07a([|"50: 10 5"|]), 50)
    // 11 can't be made from 10 and 5 with + or *
    assert_eq(Day07.day07a([|"11: 10 5"|]), 0)
}

// Multiple operators needed: 292 = 11 + 6 * 16 + 20
fn test_day07_four_numbers() {
    assert_eq(Day07.day07a([|"292: 11 6 16 20"|]), 292)
}

// Part B: concatenation enables 156 = 15 || 6
fn test_day07_concat_simple() {
    // 156: 15 6 - only solvable with concatenation
    assert_eq(Day07.day07a([|"156: 15 6"|]), 0)
    assert_eq(Day07.day07b([|"156: 15 6"|]), 156)
}

// Part B: 7290 = 6 * 8 || 6 * 15
fn test_day07_concat_mixed() {
    assert_eq(Day07.day07a([|"7290: 6 8 6 15"|]), 0)
    assert_eq(Day07.day07b([|"7290: 6 8 6 15"|]), 7290)
}

// Part B: 192 = 17 || 8 + 14
fn test_day07_concat_then_add() {
    assert_eq(Day07.day07a([|"192: 17 8 14"|]), 0)
    assert_eq(Day07.day07b([|"192: 17 8 14"|]), 192)
}

// Edge case: single number equals target
fn test_day07_single_number() {
    assert_eq(Day07.day07a([|"5: 5"|]), 5)
    assert_eq(Day07.day07a([|"5: 3"|]), 0)
}

// Empty lines are skipped
fn test_day07_empty_lines() {
    assert_eq(Day07.day07a([|"190: 10 19", "", "29: 10 19"|]), 219)
}