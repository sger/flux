// parity-expected-stdout-begin
// parity-expected-stdout-end

// HOF callback effects propagate via explicit row tails.

fn map_passthrough(xs, f) {
    map(xs, f)
}

fn add_one(n: Int) -> Int {
    n + 1
}

fn main() -> Unit {
    let doubled = map_passthrough([1, 2, 3], add_one)
    let _ = doubled
}
