define internal fastcc i64 @flux_make_adt(ptr %fields, i32 %field_count, i32 %ctor_tag) alwaysinline {
entry:
  %payload.bytes = mul i32 %field_count, 8
  %alloc.bytes = add i32 %payload.bytes, 8
  %mem = call fastcc ptr @flux_bump_alloc_inline(i32 %alloc.bytes, i32 %field_count, i32 242)
  %tag.ptr = getelementptr inbounds %FluxAdt, ptr %mem, i32 0, i32 0
  store i32 %ctor_tag, ptr %tag.ptr, align 4
  %field_count.ptr = getelementptr inbounds %FluxAdt, ptr %mem, i32 0, i32 1
  store i32 %field_count, ptr %field_count.ptr, align 4
  %payload.ptr = getelementptr inbounds %FluxAdt, ptr %mem, i32 0, i32 2, i32 0
  call fastcc void @flux_copy_i64s(ptr %payload.ptr, ptr %fields, i32 %field_count)
  %boxed = call fastcc i64 @flux_tag_boxed_ptr(ptr %mem)
  ret i64 %boxed
}

define internal fastcc i64 @flux_make_cons(i64 %head, i64 %tail) alwaysinline {
entry:
  %fields = alloca i64, i32 2, align 8
  %head.ptr = getelementptr inbounds i64, ptr %fields, i32 0
  store i64 %head, ptr %head.ptr, align 8
  %tail.ptr = getelementptr inbounds i64, ptr %fields, i32 1
  store i64 %tail, ptr %tail.ptr, align 8
  %boxed = call fastcc i64 @flux_make_adt(ptr %fields, i32 2, i32 4)
  ret i64 %boxed
}

define internal fastcc i64 @flux_make_tuple(ptr %fields, i32 %arity) alwaysinline {
entry:
  %payload.bytes = mul i32 %arity, 8
  %alloc.bytes = add i32 %payload.bytes, 8
  %mem = call fastcc ptr @flux_bump_alloc_inline(i32 %alloc.bytes, i32 %arity, i32 243)
  %tag.ptr = getelementptr inbounds %FluxTuple, ptr %mem, i32 0, i32 0
  store i8 243, ptr %tag.ptr, align 1
  %arity.ptr = getelementptr inbounds %FluxTuple, ptr %mem, i32 0, i32 4
  store i32 %arity, ptr %arity.ptr, align 4
  %payload.ptr = getelementptr inbounds %FluxTuple, ptr %mem, i32 0, i32 5, i32 0
  call fastcc void @flux_copy_i64s(ptr %payload.ptr, ptr %fields, i32 %arity)
  %boxed = call fastcc i64 @flux_tag_boxed_ptr(ptr %mem)
  ret i64 %boxed
}

define internal fastcc i32 @flux_tuple_len(i64 %value) alwaysinline {
entry:
  %ptr = call fastcc ptr @flux_untag_boxed_ptr(i64 %value)
  %arity.ptr = getelementptr inbounds %FluxTuple, ptr %ptr, i32 0, i32 4
  %arity = load i32, ptr %arity.ptr, align 4
  ret i32 %arity
}

define fastcc void @flux_copy_i64s(ptr %dst, ptr %src, i32 %count) {
entry:
  %empty = icmp eq i32 %count, 0
  br i1 %empty, label %done, label %loop
loop:
  %idx = phi i32 [ 0, %entry ], [ %idx.next, %loop ]
  %src.slot = getelementptr inbounds i64, ptr %src, i32 %idx
  %value = load i64, ptr %src.slot, align 8
  %dst.slot = getelementptr inbounds i64, ptr %dst, i32 %idx
  store i64 %value, ptr %dst.slot, align 8
  %idx.next = add i32 %idx, 1
  %keep = icmp slt i32 %idx.next, %count
  br i1 %keep, label %loop, label %done
done:
  ret void
}

define fastcc void @flux_retain_i64s(ptr %src, i32 %count) {
entry:
  %empty = icmp eq i32 %count, 0
  br i1 %empty, label %done, label %loop
loop:
  %idx = phi i32 [ 0, %entry ], [ %idx.next, %loop ]
  %src.slot = getelementptr inbounds i64, ptr %src, i32 %idx
  %value = load i64, ptr %src.slot, align 8
  call ccc void @flux_dup(i64 %value) nounwind
  %idx.next = add i32 %idx, 1
  %keep = icmp slt i32 %idx.next, %count
  br i1 %keep, label %loop, label %done
done:
  ret void
}

define internal fastcc i64 @flux_tag_boxed_ptr(ptr %ptr) alwaysinline {
entry:
  %tagged = ptrtoint ptr %ptr to i64
  ret i64 %tagged
}

define internal fastcc ptr @flux_untag_boxed_ptr(i64 %value) alwaysinline {
entry:
  %ptr = inttoptr i64 %value to ptr
  ret ptr %ptr
}

define internal fastcc i64 @flux_make_closure(ptr %fn_ptr, i32 %remaining_arity, ptr %capture_values, i32 %capture_count, ptr %applied_values, i32 %applied_count) alwaysinline {
entry:
  %payload_count = add i32 %capture_count, %applied_count
  %payload_bytes = mul i32 %payload_count, 8
  %size = add i32 %payload_bytes, 24
  %mem = call ccc ptr @flux_gc_alloc_header(i32 %size, i32 %payload_count, i32 245)
  %fn_ptr.slot = getelementptr inbounds %FluxClosure, ptr %mem, i32 0, i32 0
  store ptr %fn_ptr, ptr %fn_ptr.slot, align 8
  %remaining.slot = getelementptr inbounds %FluxClosure, ptr %mem, i32 0, i32 1
  store i32 %remaining_arity, ptr %remaining.slot, align 4
  %capture.slot = getelementptr inbounds %FluxClosure, ptr %mem, i32 0, i32 2
  store i32 %capture_count, ptr %capture.slot, align 4
  %applied.slot = getelementptr inbounds %FluxClosure, ptr %mem, i32 0, i32 3
  store i32 %applied_count, ptr %applied.slot, align 4
  %payload = getelementptr inbounds %FluxClosure, ptr %mem, i32 0, i32 5, i32 0
  call fastcc void @flux_copy_i64s(ptr %payload, ptr %capture_values, i32 %capture_count)
  call fastcc void @flux_retain_i64s(ptr %payload, i32 %capture_count)
  %applied.dst = getelementptr inbounds i64, ptr %payload, i32 %capture_count
  call fastcc void @flux_copy_i64s(ptr %applied.dst, ptr %applied_values, i32 %applied_count)
  call fastcc void @flux_retain_i64s(ptr %applied.dst, i32 %applied_count)
  %tagged = call fastcc i64 @flux_tag_boxed_ptr(ptr %mem)
  ret i64 %tagged
}

define internal fastcc i64 @flux_call_closure(i64 %closure_value, ptr %args, i32 %nargs) alwaysinline {
entry:
  %closure = call fastcc ptr @flux_untag_boxed_ptr(i64 %closure_value)
  %fn_ptr.slot = getelementptr inbounds %FluxClosure, ptr %closure, i32 0, i32 0
  %fn_ptr = load ptr, ptr %fn_ptr.slot, align 8
  %remaining.slot = getelementptr inbounds %FluxClosure, ptr %closure, i32 0, i32 1
  %remaining_arity = load i32, ptr %remaining.slot, align 4
  %capture.slot = getelementptr inbounds %FluxClosure, ptr %closure, i32 0, i32 2
  %capture_count = load i32, ptr %capture.slot, align 4
  %applied.slot = getelementptr inbounds %FluxClosure, ptr %closure, i32 0, i32 3
  %applied_count = load i32, ptr %applied.slot, align 4
  %payload = getelementptr inbounds %FluxClosure, ptr %closure, i32 0, i32 5, i32 0
  %is_exact = icmp eq i32 %nargs, %remaining_arity
  %is_under = icmp slt i32 %nargs, %remaining_arity
  br i1 %is_exact, label %exact, label %non_exact
non_exact:
  br i1 %is_under, label %under, label %over
exact:
  %exact.result = call ccc i64 %fn_ptr(i64 %closure_value, ptr %args, i32 %nargs)
  ret i64 %exact.result
under:
  %existing.applied = getelementptr inbounds i64, ptr %payload, i32 %capture_count
  %new.applied.count = add i32 %applied_count, %nargs
  %new.applied = alloca i64, i32 %new.applied.count, align 8
  call fastcc void @flux_copy_i64s(ptr %new.applied, ptr %existing.applied, i32 %applied_count)
  %new.applied.tail = getelementptr inbounds i64, ptr %new.applied, i32 %applied_count
  call fastcc void @flux_copy_i64s(ptr %new.applied.tail, ptr %args, i32 %nargs)
  %new.remaining = sub i32 %remaining_arity, %nargs
  %under.result = call fastcc i64 @flux_make_closure(ptr %fn_ptr, i32 %new.remaining, ptr %payload, i32 %capture_count, ptr %new.applied, i32 %new.applied.count)
  ret i64 %under.result
