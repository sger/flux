{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Flux",
  "scopeName": "source.flux",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#annotations" },
    { "include": "#operators" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#type-annotations" },
    { "include": "#identifiers" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "include": "#doc-block-comment" },
        { "include": "#block-comment" },
        { "include": "#line-comment" }
      ]
    },
    "doc-block-comment": {
      "name": "comment.block.documentation.flux",
      "begin": "/\\*\\*",
      "end": "\\*/",
      "patterns": [
        { "include": "#doc-block-comment-nested" }
      ]
    },
    "doc-block-comment-nested": {
      "patterns": [
        {
          "name": "comment.block.documentation.flux",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "include": "#doc-block-comment-nested" }
          ]
        }
      ]
    },
    "block-comment": {
      "name": "comment.block.flux",
      "begin": "/\\*",
      "end": "\\*/",
      "patterns": [
        { "include": "#block-comment" }
      ]
    },
    "line-comment": {
      "name": "comment.line.double-slash.flux",
      "match": "//.*$"
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.flux",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.flux",
              "match": "\\\\(?:[\\\\\"nrtbf0]|x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]{1,6}\\})"
            },
            {
              "name": "meta.interpolation.flux",
              "begin": "#\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.section.interpolation.begin.flux" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.section.interpolation.end.flux" }
              },
              "patterns": [
                { "include": "source.flux" }
              ]
            }
          ]
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "comment": "Annotation: @fip, @fbip, @inline — same scope as types (IO, etc.)",
          "name": "entity.name.type.flux",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.flux",
          "match": "\\b0[xX][0-9A-Fa-f][0-9A-Fa-f_]*\\b"
        },
        {
          "name": "constant.numeric.binary.flux",
          "match": "\\b0[bB][01][01_]*\\b"
        },
        {
          "name": "constant.numeric.octal.flux",
          "match": "\\b0[oO][0-7][0-7_]*\\b"
        },
        {
          "name": "constant.numeric.float.flux",
          "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*(?:[eE][+-]?\\d[\\d_]*)?\\b"
        },
        {
          "name": "constant.numeric.integer.flux",
          "match": "\\b\\d[\\d_]*\\b"
        }
      ]
    },
    "type-annotations": {
      "patterns": [
        {
          "comment": "Type annotation after colon: x: Int, x: List<a>",
          "match": "(?<=:)\\s*([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.type.flux" }
          }
        },
        {
          "comment": "Return type after arrow: -> Int",
          "match": "(?<=->)\\s*([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.type.flux" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "comment": "Function and binding declarations",
          "name": "keyword.declaration.flux",
          "match": "\\b(?:fn|let|data|effect|class|instance|deriving|type|module|public)\\b"
        },
        {
          "comment": "Control flow",
          "name": "keyword.control.flux",
          "match": "\\b(?:if|else|match|return|do|handle|perform|with|where)\\b"
        },
        {
          "comment": "Module system",
          "name": "keyword.control.import.flux",
          "match": "\\b(?:import|as|exposing|except)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.flux",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "comment": "Built-in type names",
          "name": "support.type.primitive.flux",
          "match": "\\b(?:Int|Float|String|Bool|Unit|Char)\\b"
        },
        {
          "comment": "Built-in parameterised types",
          "name": "support.type.flux",
          "match": "\\b(?:List|Array|Option|Either|Map)\\b"
        },
        {
          "comment": "Built-in constructors",
          "name": "support.type.variant.flux",
          "match": "\\b(?:Some|None|Left|Right|Ok|Err)\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "comment": "Function definition: fn name",
          "match": "\\b(fn)\\s+([a-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.flux" },
            "2": { "name": "entity.name.function.flux" }
          }
        },
        {
          "comment": "Module or data declaration: module Name, data Name",
          "match": "\\b(module|data|class|instance|effect)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.flux" },
            "2": { "name": "entity.name.type.flux" }
          }
        },
        {
          "comment": "Qualified module call: Module.func(",
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\.([a-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.type.flux" },
            "2": { "name": "entity.name.function.call.flux" }
          }
        },
        {
          "comment": "Function call: name(",
          "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.flux" }
          }
        },
        {
          "comment": "Function reference after pipe: |> func (no parens)",
          "match": "(?<=\\|>)\\s*([a-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.function.call.flux" }
          }
        },
        {
          "comment": "Type / constructor name (uppercase start)",
          "name": "entity.name.type.flux",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "comment": "Wildcard pattern",
          "name": "variable.language.wildcard.flux",
          "match": "\\b_\\b"
        },
        {
          "comment": "Regular variable / parameter",
          "name": "variable.other.flux",
          "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "comment": "Pipe operator: |>",
          "name": "keyword.operator.pipe.flux",
          "match": "\\|>"
        },
        {
          "comment": "Arrow: -> <-",
          "name": "keyword.operator.arrow.flux",
          "match": "->|<-"
        },
        {
          "comment": "Comparison: == != <= >=",
          "name": "keyword.operator.comparison.flux",
          "match": "==|!=|<=|>="
        },
        {
          "comment": "Logical OR: ||",
          "name": "keyword.operator.logical.flux",
          "match": "\\|\\|"
        },
        {
          "comment": "Logical AND: &&",
          "name": "keyword.operator.logical.flux",
          "match": "&&"
        },
        {
          "comment": "Lambda backslash",
          "name": "keyword.operator.lambda.flux",
          "match": "\\\\"
        },
        {
          "comment": "Cons operator: | (not followed by > or |)",
          "name": "keyword.operator.cons.flux",
          "match": "\\|(?![|>])"
        },
        {
          "comment": "Assignment: = (not ==, !=, <=, >=, =>)",
          "name": "keyword.operator.assignment.flux",
          "match": "(?<![=!<>])=(?![=>])"
        },
        {
          "comment": "Math: + * / %",
          "name": "keyword.operator.math.flux",
          "match": "[+*%]"
        },
        {
          "comment": "Minus (not part of ->)",
          "name": "keyword.operator.math.flux",
          "match": "-(?!>)"
        },
        {
          "comment": "Division (not comment //)",
          "name": "keyword.operator.math.flux",
          "match": "/(?!/)"
        },
        {
          "comment": "Not: ! (not !=)",
          "name": "keyword.operator.logical.flux",
          "match": "!(?!=)"
        },
        {
          "comment": "Less-than (not <- or <=)",
          "name": "keyword.operator.comparison.flux",
          "match": "<(?![-=])"
        },
        {
          "comment": "Greater-than (not >=; previous char not - or =)",
          "name": "keyword.operator.comparison.flux",
          "match": "(?<![-=])>(?!=)"
        },
        {
          "comment": "Dot accessor",
          "name": "keyword.operator.access.dot.flux",
          "match": "\\."
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.comma.flux",
          "match": ","
        },
        {
          "name": "punctuation.semi.flux",
          "match": ";"
        },
        {
          "name": "punctuation.colon.flux",
          "match": ":"
        },
        {
          "name": "punctuation.brackets.curly.flux",
          "match": "[{}]"
        },
        {
          "name": "punctuation.brackets.round.flux",
          "match": "[()]"
        },
        {
          "name": "punctuation.brackets.square.flux",
          "match": "[\\[\\]]"
        },
        {
          "comment": "Hash for interpolation / records",
          "name": "punctuation.definition.hash.flux",
          "match": "#"
        }
      ]
    }
  }
}
