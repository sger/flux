// parity-expected-stdout-end

import Flow except [print]

module BaseExamples.ExceptInModule {
    fn run() with IO {
        let xs = [10, 20, 30]

        print("module len(xs) = " + to_string(len(xs)))
        print("module first(xs) = " + to_string(first(xs)))
    }
}