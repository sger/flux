// parity: vm, llvm
// expect: success
// bug: Non-tail-resumptive exception-style handler (discard continuation).
//      VM uses the full continuation capture path; native unwinds via yield.
//      Both must agree on the short-circuited return value.
// parity-expected-stdout-begin
// "-1"
// parity-expected-stdout-end

effect Fail {
    raise : (String) -> Int
}

fn safe_div(a: Int, b: Int) -> Int with Fail {
    if b == 0 {
        perform Fail.raise("division by zero")
    } else {
        a / b
    }
}

fn main() with IO {
    let result = safe_div(10, 0) handle Fail {
        raise(resume, _msg) -> 0 - 1
    }
    print(to_string(result))
}
