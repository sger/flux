          shared -> case keep#16 of
              true →
                aether_call[owned, owned, owned, owned] Node#?[external](color#17, left#18, key#19, right#20)
              _ →
                drop right#20
                aether_call[owned, owned, owned, owned] Node#?[external](color#17, dup left#18
                left#18, key#19, left#18)
        }
      _ →
        t#15

