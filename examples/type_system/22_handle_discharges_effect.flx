// Handle discharges an effect requirement from a call chain.

effect Logger {
    print: String -> ()
}

fn log(msg: String) -> Unit with Logger {
    perform Logger.print(msg)
}

fn run() -> Int {
    log("ok") handle Logger {
        print(resume, _msg) -> resume(())
    }
    1
}

fn main() with IO {
    print(to_string(run()))
}

