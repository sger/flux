// parity: vm, llvm
// expect: success
// bug: typed arithmetic (IAdd, ISub, IMul) on the native backend may
//       diverge from polymorphic Add/Sub/Mul on the VM when FluxRep
//       dispatch picks the wrong path.

fn main() with IO {
    print(2 + 3);
    print(10 - 4);
    print(6 * 7);
    print(10 / 3);
    print(10 % 3);

    print(2.5 + 1.5);
    print(10.0 - 3.5);
    print(2.0 * 3.5);

    print(-42);
    print(-(2 + 3));
}
