// Tests for pipe operator and higher-order functions (map, filter, fold,
// find, any, all, zip, flatten, count, sort_by, flat_map).

// --- pipe operator ---

fn double(x) { x * 2 }
fn add1(x) { x + 1 }

fn test_pipe_basic() {
    let result = 5 |> double
    assert_eq(result, 10)
}

fn test_pipe_chained() {
    let result = 5 |> double |> add1
    assert_eq(result, 11)
}

fn add(a, b) { a + b }

fn test_pipe_with_partial_args() {
    let result = 5 |> add(3)
    assert_eq(result, 8)
}

fn test_pipe_array_operations() {
    let result = [|1, 2, 3, 4, 5|]
        |> filter(\x -> x > 2)
        |> map(\x -> x * 10)
    assert_eq(len(result), 3)
    assert_eq(result[0], Some(30))
    assert_eq(result[1], Some(40))
    assert_eq(result[2], Some(50))
}

// --- map ---

fn test_map_basic() {
    let result = map([|1, 2, 3|], \x -> x * 2)
    assert_eq(len(result), 3)
    assert_eq(result[0], Some(2))
    assert_eq(result[1], Some(4))
    assert_eq(result[2], Some(6))
}

fn test_map_strings() {
    let result = map([|"a", "b"|], \s -> s + "!")
    assert_eq(len(result), 2)
    assert_eq(result[0], Some("a!"))
    assert_eq(result[1], Some("b!"))
}

fn test_map_empty() {
    let result = map([||], \x -> x + 1)
    assert_eq(len(result), 0)
}

// --- filter ---

fn test_filter_basic() {
    let result = filter([|1, 2, 3, 4, 5|], \x -> x > 3)
    assert_eq(len(result), 2)
    assert_eq(result[0], Some(4))
    assert_eq(result[1], Some(5))
}

fn test_filter_none_match() {
    let result = filter([|1, 2, 3|], \x -> x > 10)
    assert_eq(len(result), 0)
}

fn test_filter_all_match() {
    let result = filter([|1, 2, 3|], \x -> x > 0)
    assert_eq(len(result), 3)
    assert_eq(result[0], Some(1))
    assert_eq(result[1], Some(2))
    assert_eq(result[2], Some(3))
}

// --- fold ---

fn test_fold_sum() {
    let result = fold([|1, 2, 3, 4|], 0, \(acc, x) -> acc + x)
    assert_eq(result, 10)
}

fn test_fold_product() {
    let result = fold([|1, 2, 3, 4|], 1, \(acc, x) -> acc * x)
    assert_eq(result, 24)
}

fn test_fold_string_concat() {
    let result = fold([|"a", "b", "c"|], "", \(acc, s) -> acc + s)
    assert_eq(result, "abc")
}

fn test_fold_empty() {
    let result = fold([||], 42, \(acc, x) -> acc + x)
    assert_eq(result, 42)
}

// --- find ---

fn test_find_found() {
    let result = find([|1, 2, 3, 4|], \x -> x > 2)
    assert_eq(result, Some(3))
}

fn test_find_not_found() {
    let result = find([|1, 2, 3|], \x -> x > 10)
    assert_eq(result, None)
}

// --- any / all ---

fn test_any_true() {
    assert_true(any([|1, 2, 3|], \x -> x == 2))
}

fn test_any_false() {
    assert_false(any([|1, 2, 3|], \x -> x > 10))
}

fn test_all_true() {
    assert_true(all([|2, 4, 6|], \x -> x % 2 == 0))
}

fn test_all_false() {
    assert_false(all([|1, 2, 3|], \x -> x > 2))
}

// --- zip ---

fn test_zip_basic() {
    let result = zip([|1, 2, 3|], [|"a", "b", "c"|])
    assert_eq(len(result), 3)
    assert_eq(result[0], Some((1, "a")))
    assert_eq(result[1], Some((2, "b")))
    assert_eq(result[2], Some((3, "c")))
}

fn test_zip_different_lengths() {
    let result = zip([|1, 2|], [|"a", "b", "c"|])
    assert_eq(len(result), 2)
}

// --- flatten ---

fn test_flatten_basic() {
    let result = flatten([|[|1, 2|], [|3, 4|], [|5|]|])
    assert_eq(len(result), 5)
    assert_eq(result[0], Some(1))
    assert_eq(result[4], Some(5))
}

fn test_flatten_with_empty() {
    let result = flatten([|[|1|], [||], [|2, 3|]|])
    assert_eq(len(result), 3)
    assert_eq(result[0], Some(1))
    assert_eq(result[1], Some(2))
    assert_eq(result[2], Some(3))
}

// --- flat_map ---

fn test_flat_map_basic() {
    let result = flat_map([|1, 2, 3|], \x -> [|x, x * 10|])
    assert_eq(len(result), 6)
    assert_eq(result[0], Some(1))
    assert_eq(result[1], Some(10))
    assert_eq(result[2], Some(2))
    assert_eq(result[3], Some(20))
}

// --- count ---

fn test_count_basic() {
    let result = count([|1, 2, 3, 4, 5|], \x -> x > 3)
    assert_eq(result, 2)
}

fn test_count_none() {
    let result = count([|1, 2, 3|], \x -> x > 10)
    assert_eq(result, 0)
}

// --- sort_by ---

fn test_sort_by_identity() {
    let result = sort_by([|3, 1, 2|], \x -> x)
    assert_eq(len(result), 3)
    assert_eq(result[0], Some(1))
    assert_eq(result[1], Some(2))
    assert_eq(result[2], Some(3))
}

fn test_sort_by_key() {
    let result = sort_by([|(1, "c"), (3, "a"), (2, "b")|], \t -> t.0)
    assert_eq(first(result), Some((1, "c")))
    assert_eq(last(result), Some((3, "a")))
}

// --- combined higher-order pipelines ---

fn test_pipeline_filter_map_fold() {
    let result = [|1, 2, 3, 4, 5, 6|]
        |> filter(\x -> x % 2 == 0)
        |> map(\x -> x * x)
        |> fold(0, \(acc, x) -> acc + x)
    assert_eq(result, 56)
}
