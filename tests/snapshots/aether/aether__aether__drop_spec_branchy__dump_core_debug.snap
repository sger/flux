letrec copy_or_keep_head : List<Any> =
λxs#1, copy#2.
    case xs#1 of
      ::(h#3, t#4) →
        drop_spec xs#1 {
          unique -> case copy#2 of
              true →
                let #4000014[synthetic]#14 = ::(h#3, t#4)
                reuse xs#1 ::(h#3, #4000014[synthetic]#14) @mask=0b10
              _ →
                reuse xs#1 ::(h#3, t#4) @mask=0b0
          shared -> case copy#2 of
              true →
                let #4000014[synthetic]#14 = ::(dup h#3
                h#3, t#4)
                ::(h#3, #4000014[synthetic]#14)
              _ →
                ::(h#3, t#4)
        }
      _ →
        []

letrec keep_or_dup_left : Tree =
λt#6, keep#7.
    case t#6 of
      Node(color#8, left#9, key#10, right#11) →
        drop_spec t#6 {
          unique -> case keep#7 of
              true →
                reuse t#6 Node(color#8, left#9, key#10, right#11) @mask=0b0
              _ →
                drop right#11
                reuse t#6 Node(color#8, left#9, key#10, left#9) @mask=0b1000
          shared -> case keep#7 of
              true →
                aether_call[owned, owned, owned, owned] Node#?[external](color#8, left#9, key#10, right#11)
              _ →
                drop right#11
                aether_call[owned, owned, owned, owned] Node#?[external](color#8, dup left#9
                left#9, key#10, left#9)
        }
      _ →
        t#6

