// parity-expected-stdout-begin
// parity-expected-stdout-end

import Flow.FTest as Test
import Day05Solver as Day05

// Helper for sample lines.
fn sample_lines() {
    [|
        "47|53",
        "97|13",
        "97|61",
        "97|47",
        "75|29",
        "61|13",
        "75|53",
        "29|13",
        "97|29",
        "53|29",
        "61|53",
        "97|53",
        "61|29",
        "47|13",
        "75|47",
        "97|75",
        "47|61",
        "75|61",
        "47|29",
        "75|13",
        "53|13",
        "",
        "75,47,61,53,29",
        "97,61,53,29,13",
        "75,29,13",
        "75,97,47,61,53",
        "61,13,29",
        "97,13,75,29,47",
    |]
}

// Helper for test DAY05 part1 prompt sample is 143.
fn test_day05_part1_prompt_sample_is_143() {
    Test.eq(Day05.day05a_from_lines(sample_lines()), 143)
}

// Helper for test DAY05 part1 ignores missing page rules.
fn test_day05_part1_ignores_missing_page_rules() {
    let lines = [|
        "10|20",
        "20|30",
        "",
        "10,30",
        "10,20,30",
    |]
    // Both updates are valid: first ignores 20-related ordering because 20 is missing.
    // Middles: 30 and 20 => 50
    Test.eq(Day05.day05a_from_lines(lines), 50)
}

// Helper for test DAY05 part1 rejects violating updates.
fn test_day05_part1_rejects_violating_updates() {
    let lines = [|
        "10|20",
        "",
        "10,20,30",
        "20,10,30",
    |]
    // Only first update is valid; middle is 20.
    Test.eq(Day05.day05a_from_lines(lines), 20)
}

// Helper for test DAY05 part1 memory and lines match.
fn test_day05_part1_memory_and_lines_match() {
    let memory =
    "1|2\n" +
    "2|3\n" +
    "\n" +
    "1,2,3\n" +
    "2,1,3\n"

    let lines = [|
        "1|2",
        "2|3",
        "",
        "1,2,3",
        "2,1,3",
    |]

    Test.eq(Day05.day05a_from_memory(memory), Day05.day05a_from_lines(lines))
}