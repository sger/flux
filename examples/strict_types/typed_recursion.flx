// parity: vm, llvm
// expect: success
// Typed recursive functions — passes --strict-types.

fn factorial(n: Int) -> Int {
    if n <= 1 {
        1
    } else {
        n * factorial(n - 1)
    }
}

fn fibonacci(n: Int) -> Int {
    if n <= 1 {
        n
    } else {
        fibonacci(n - 1) + fibonacci(n - 2)
    }
}

fn main() with IO {
    print(factorial(5))
    print(factorial(10))
    print(fibonacci(10))
}
