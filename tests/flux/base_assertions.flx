// Tests for base assertion functions: assert_eq, assert_neq, assert_true,
// assert_false, assert_throws, assert_msg, try, str_contains,
// assert_gt, assert_lt, assert_gte, assert_lte, and assert_len.

// --- assert_eq ---

fn test_assert_eq_integers() {
    assert_eq(1 + 1, 2)
}

fn test_assert_eq_strings() {
    assert_eq("hello" + " world", "hello world")
}

fn test_assert_eq_booleans() {
    assert_eq(true, true)
    assert_eq(false, false)
}

fn test_assert_eq_floats() {
    assert_eq(1.0 + 2.0, 3.0)
}

fn test_assert_eq_arrays() {
    assert_eq([1, 2, 3], [1, 2, 3])
}

fn test_assert_eq_empty_list() {
    assert_eq([], [])
}

fn test_assert_eq_cons_list() {
    assert_eq(list(1, 2, 3), list(1, 2, 3))
}

fn test_assert_eq_tuples() {
    assert_eq((1, "a"), (1, "a"))
}

fn test_assert_eq_nested() {
    assert_eq([|[|1, 2|], [|3, 4|]|], [|[|1, 2|], [|3, 4|]|])
}

fn test_assert_eq_maps() {
    let a = put(put({}, "x", 1), "y", 2)
    let b = put(put({}, "y", 2), "x", 1)
    assert_eq(a, b)
}

// --- assert_neq ---

fn test_assert_neq_integers() {
    assert_neq(1, 2)
}

fn test_assert_neq_strings() {
    assert_neq("hello", "world")
}

fn test_assert_neq_different_values() {
    assert_neq(1, 2)
}

// --- assert_true / assert_false ---

fn test_assert_true_basic() {
    assert_true(1 == 1)
    assert_true(10 > 5)
}

fn test_assert_false_basic() {
    assert_false(1 == 2)
    assert_false(5 > 10)
}

// --- assert_throws ---

fn test_assert_throws_one_arg() {
    assert_throws(\() -> 1 / 0)
}

fn test_assert_throws_two_args() {
    assert_throws(\() -> 1 / 0, "division by zero")
}

fn test_assert_throws_wrong_arity() {
    assert_throws(\x -> x, "wrong number of arguments")
}

// --- assert_msg ---

fn test_assert_msg_passes() {
    assert_msg(true, "should not see this")
}

fn test_assert_msg_custom_message() {
    let result = try(\() -> assert_msg(false, "custom failure reason"))
    assert_eq(result.0, "error")
    assert_true(is_string(result.1))
}

// --- try ---

fn test_try_ok() {
    let result = try(\() -> 42)
    assert_eq(result.0, "ok")
    assert_eq(result.1, 42)
}

fn test_try_error() {
    let result = try(\() -> 1 / 0)
    assert_eq(result.0, "error")
    assert_true(is_string(result.1))
}

fn test_try_does_not_propagate() {
    let r1 = try(\() -> assert_eq(1, 2))
    let r2 = try(\() -> 100)
    assert_eq(r1.0, "error")
    assert_eq(r2.0, "ok")
    assert_eq(r2.1, 100)
}

// --- str_contains ---

fn test_str_contains_found() {
    assert_true(str_contains("hello world", "world"))
    assert_true(str_contains("hello world", "hello"))
    assert_true(str_contains("hello world", " "))
}

fn test_str_contains_not_found() {
    assert_false(str_contains("hello world", "xyz"))
    assert_false(str_contains("hello", "HELLO"))
}

fn test_str_contains_empty_needle() {
    assert_true(str_contains("hello", ""))
}

// --- assert_gt ---

fn test_assert_gt_passes() {
    assert_gt(5, 3)
    assert_gt(3.14, 2.71)
    assert_gt(10.0, 9.99)
}

fn test_assert_gt_fails() {
    let result = try(\() -> assert_gt(3, 5))
    assert_eq(result.0, "error")
    assert_true(str_contains(result.1, "assert_gt failed"))
}

// --- assert_lt ---

fn test_assert_lt_passes() {
    assert_lt(1, 5)
    assert_lt(2.5, 3.0)
}

fn test_assert_lt_fails() {
    let result = try(\() -> assert_lt(5, 3))
    assert_eq(result.0, "error")
    assert_true(str_contains(result.1, "assert_lt failed"))
}

// --- assert_gte ---

fn test_assert_gte_passes() {
    assert_gte(5, 5)
    assert_gte(6, 5)
}

fn test_assert_gte_fails() {
    let result = try(\() -> assert_gte(3, 5))
    assert_eq(result.0, "error")
    assert_true(str_contains(result.1, "assert_gte failed"))
}

// --- assert_lte ---

fn test_assert_lte_passes() {
    assert_lte(5, 5)
    assert_lte(4, 5)
}

fn test_assert_lte_fails() {
    let result = try(\() -> assert_lte(5, 3))
    assert_eq(result.0, "error")
    assert_true(str_contains(result.1, "assert_lte failed"))
}

// --- assert_len ---

fn test_assert_len_array() {
    assert_len([1, 2, 3], 3)
    assert_len([], 0)
}

fn test_assert_len_string() {
    assert_len("hello", 5)
    assert_len("", 0)
}

fn test_assert_len_fails() {
    let result = try(\() -> assert_len([1, 2], 5))
    assert_eq(result.0, "error")
    assert_true(str_contains(result.1, "assert_len failed"))
}
