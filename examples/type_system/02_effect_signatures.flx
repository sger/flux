fn main() with Console, Clock {
    fn now_plus(delta: Int) -> Int with Clock {
        now_ms() + delta
    }

    fn log_now(prefix: String) with Console, Clock {
        let t = now_plus(0)
        print("#{prefix}#{t}")
    }

    fn greet(name: String) with Console {
        print("Hello, #{name}")
    }

    log_now("timestamp=")
    greet("Flux")
}