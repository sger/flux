// parity: vm, llvm
// expect: success
// bug: basic handle/perform for algebraic effects may crash the native
//       backend when evidence passing lowers incorrectly.
// parity-expected-stdout-begin
// "Hello, world!"
// parity-expected-stdout-end

effect Greet {
    greet : (String) -> String
}

fn hello(name: String) -> String with Greet {
    perform Greet.greet(name)
}

fn main() with IO {
    let result = hello("world") handle Greet {
        greet(resume, _name) -> resume("Hello, world!")
    }
    print(result)
}
