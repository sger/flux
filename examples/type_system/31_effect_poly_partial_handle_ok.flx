// parity-expected-stdout-begin
// "7"
// parity-expected-stdout-end

// Effect-polymorphic wrapper + local handle discharge.

effect Logger {
    print: String -> ()
}

fn run_task(f: (() -> Int with |e)) -> Int with |e {
    f()
}

fn task() -> Int with Logger {
    perform Logger.print("ok")
    7
}

fn run() -> Int {
    run_task(task) handle Logger {
        print(resume, _msg) -> resume(())
    }
}

fn main() with IO {
    print(to_string(run()))
}
