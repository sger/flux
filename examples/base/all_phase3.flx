// Aggregated Phase 3 Base smoke example (valid path only)

import Base except [print]

Base.print("== Base directives smoke ==");
Base.print("len([1,2,3]) = " + to_string(len([1, 2, 3])));

fn shadow_demo() {
  let len = fn(x) { 123 };
  let xs = [10, 20, 30, 40];

  Base.print("local len(xs) = " + to_string(len(xs)));
  Base.print("Base.len(xs) = " + to_string(Base.len(xs)));
}

shadow_demo();
