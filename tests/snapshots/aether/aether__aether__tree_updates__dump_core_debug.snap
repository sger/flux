letrec set_black : Tree =
λt#1.
    case t#1 of
      Node(_, left#2, key#3, right#4) →
        drop_spec t#1 {
          unique -> reuse t#1 Node(Black#?[external], left#2, key#3, right#4) @mask=0b1
          shared -> aether_call[owned, owned, owned, owned] Node#?[external](Black#?[external], dup left#2
            left#2, dup key#3
            key#3, dup right#4
            right#4)
        }
      _ →
        t#1

