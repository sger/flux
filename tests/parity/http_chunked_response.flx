// parity: vm
// expect: success
//
// Phase 2 HTTP polish: client-side chunked transfer decoding.
//
// Server hand-rolls a response with `Transfer-Encoding: chunked` —
// three data chunks plus the terminator. Client uses Http.get and
// expects the body re-assembled into the concatenation of the chunks.

import Flow.Async as A
import Flow.Bytes as Bytes
import Flow.Http as Http
import Flow.String as String
import Flow.Tcp as Tcp

fn port_from_addr(addr: String) -> Int {
    let parts = split(addr, ":")
    match parts[1] {
        Some(port) -> parse_int(port),
        _ -> 0,
    }
}

fn drain_request(conn) -> String with Async {
    drain_request_loop(conn, "")
}

fn drain_request_loop(conn, acc: String) -> String with Async {
    let chunk = Tcp.read(conn, 1024)
    let combined = acc + Bytes.to_string(chunk)
    if len(combined) == 0 {
        combined
    } else {
        let idx = match index_of(combined, "\r\n\r\n") {
            Some(_) -> 1,
            None -> 0,
        }
        if idx == 1 {
            combined
        } else {
            drain_request_loop(conn, combined)
        }
    }
}

fn index_of(haystack: String, needle: String) -> Option<Int> {
    let h = len(haystack)
    let n = len(needle)
    if n == 0 || n > h {
        None
    } else {
        index_of_loop(haystack, needle, 0, h - n + 1, n)
    }
}

fn index_of_loop(haystack: String, needle: String, i: Int, end: Int, n: Int) -> Option<Int> {
    if i >= end {
        None
    } else if String.string_slice(haystack, i, i + n) == needle {
        Some(i)
    } else {
        index_of_loop(haystack, needle, i + 1, end, n)
    }
}

fn main() with IO, Async {
    let listener = Tcp.listen("127.0.0.1", 0)
    let port = port_from_addr(Tcp.listener_local_addr(listener))
    let url = "http://127.0.0.1:" + to_string(port) + "/chunked"

    let pair = A.both(
        fn() {
            // Server: send a chunked response.
            //   "5\r\nhello\r\n7\r\n, flux!\r\n6\r\n done.\r\n0\r\n\r\n"
            // decoded body should be: "hello, flux! done."
            let conn = Tcp.accept(listener)
            let _ = drain_request(conn)
            let chunked_body =
                "5\r\nhello\r\n" +
                "7\r\n, flux!\r\n" +
                "6\r\n done.\r\n" +
                "0\r\n\r\n"
            let response =
                "HTTP/1.1 200 OK\r\n" +
                "Transfer-Encoding: chunked\r\n" +
                "Connection: close\r\n" +
                "\r\n" +
                chunked_body
            let written = Tcp.write(conn, String.to_bytes(response))
            Tcp.close(conn);
            written
        },
        fn() {
            let response = Http.get(url)
            response.body
        }
    );

    Tcp.close_listener(listener);
    match pair {
        (_, body) -> print("body=" + body),
    }
}
