// parity: vm, llvm
// expect: success
// Fully typed ADT construction and pattern matching — passes the default static-typing checks.

data Shape {
    Circle(Int),
    Rect(Int, Int)
}

fn area(s: Shape) -> Int {
    match s {
        Circle(r) -> r * r * 3,
        Rect(w, h) -> w * h
    }
}

fn main() with IO {
    let c = Circle(5)
    let r = Rect(4, 6)
    print(area(c))
    print(area(r))
}