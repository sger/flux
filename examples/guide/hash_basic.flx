// parity-expected-stdout-begin
// Some(1)
// Some(2)
// Some(3)
// Some("hello")
// Some("world")
// parity-expected-stdout-end

fn main() with IO {
    // Test: Basic hashes
    // Expected output:
    // 1
    // 2
    // 3
    // hello
    // world

    // String keys
    let h = {"a": 1, "b": 2, "c": 3};
    print(h["a"]);
    print(h["b"]);
    print(h["c"]);

    // Integer keys
    let nums = {1: "hello", 2: "world"};
    print(nums[1]);
    print(nums[2]);
}