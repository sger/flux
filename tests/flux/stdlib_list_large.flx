// Tests that List stdlib functions handle large lists without stack overflow.
// These functions must be tail-recursive (accumulator + reverse pattern).

fn build_list(n, acc) {
    if n <= 0 { acc }
    else { build_list(n - 1, [n | acc]) }
}

fn test_map_large_list() {
    let xs = build_list(100000, [])
    let ys = map(xs, \x -> x + 1)
    assert_eq(len(ys), 100000)
    // First element: build_list produces [1, 2, ..., 100000]
    match ys {
        [h | _] -> assert_eq(h, 2),
        _ -> panic("map produced empty list")
    }
}

fn test_filter_large_list() {
    let xs = build_list(100000, [])
    let evens = filter(xs, \x -> x % 2 == 0)
    assert_eq(len(evens), 50000)
}

fn test_map_preserves_order() {
    let xs = [1, 2, 3, 4, 5]
    let ys = map(xs, \x -> x * 10)
    assert_eq(ys, [10, 20, 30, 40, 50])
}

fn test_filter_preserves_order() {
    let xs = [1, 2, 3, 4, 5, 6]
    let odds = filter(xs, \x -> x % 2 != 0)
    assert_eq(odds, [1, 3, 5])
}

fn test_take_large_list() {
    let xs = build_list(100000, [])
    let first_10 = take(xs, 10)
    assert_eq(len(first_10), 10)
    match first_10 {
        [h | _] -> assert_eq(h, 1),
        _ -> panic("take produced empty list")
    }
}

fn test_take_while_large_list() {
    let xs = build_list(100000, [])
    let prefix = take_while(xs, \x -> x <= 50)
    assert_eq(len(prefix), 50)
}

fn test_fold_large_list() {
    let xs = build_list(50000, [])
    let total = fold(xs, 0, \(acc, x) -> acc + x)
    // sum 1..50000 = 50000 * 50001 / 2 = 1250025000
    assert_eq(total, 1250025000)
}

fn test_map_filter_pipeline() {
    let xs = build_list(50000, [])
    let result = xs
        |> map(\x -> x * 2)
        |> filter(\x -> x % 4 == 0)
        |> fold(0, \(acc, _) -> acc + 1)
    assert_eq(result, 25000)
}
