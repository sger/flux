// parity: vm, llvm
// expect: success
// bug: Conditional resume — the handler decides per-invocation whether
//      to resume or to short-circuit.  Observed (2026-04-22) baseline:
//        - VM:     runtime error E1001 on `resume(10)` inside the `if` —
//                  the VM appears to treat the arm as non-TR and hands a
//                  Continuation object, but then the expression `resume(10)`
//                  fails as "not a function" because the conditional path
//                  wasn't recognized as a direct-dispatch call site.
//        - Native: exits 0, prints "110" (= resume(10) returning 10, added
//                  to 100 from the second pick(2) branch).
//      Phase 1/3 of Proposal 0162 should fix the VM path — every shape
//      that succeeds on native must also succeed on VM.  Expected stdout
//      below reflects the native answer; today this fixture reports
//      MISMATCH which is the regression gate.
// parity-expected-stdout-begin
// "110"
// parity-expected-stdout-end

effect Choose {
    pick : (Int) -> Int
}

fn calc() -> Int with Choose {
    let a = perform Choose.pick(1)
    let b = perform Choose.pick(2)
    a + b
}

fn main() with IO {
    // Handler: pick(1) -> resume(10); pick(anything else) -> return 999
    // But we only pick 1 and 2 and the `2` case short-circuits.
    let result = calc() handle Choose {
        pick(resume, n) -> if n == 1 { resume(10) } else { 100 }
    }
    print(to_string(result))
}
