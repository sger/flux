import Flow.Array as Array
import Flow.Map as Map

// Tests for tuples, arrays, cons lists, and hash maps.

// --- tuples ---

fn test_tuple_creation() {
    let t = (1, "hello", true)
    assert_eq(t.0, 1)
    assert_eq(t.1, "hello")
    assert_eq(t.2, true)
}

fn test_tuple_pair() {
    let pair = (10, 20)
    assert_eq(pair.0, 10)
    assert_eq(pair.1, 20)
}

fn test_tuple_single_element() {
    let t = (42,)
    assert_eq(t.0, 42)
}

fn test_tuple_nested() {
    let t = (1, (2, 3))
    assert_eq(t.0, 1)
    let inner = t.1
    assert_eq(inner.0, 2)
    assert_eq(inner.1, 3)
}

fn test_tuple_destructuring() {
    let (a, b, c) = (10, 20, 30)
    assert_eq(a, 10)
    assert_eq(b, 20)
    assert_eq(c, 30)
}

fn test_tuple_in_function() {
    let swap = \(a, b) -> (b, a)
    let result = swap(1, 2)
    assert_eq(result.0, 2)
    assert_eq(result.1, 1)
}

fn test_tuple_equality() {
    assert_eq((1, 2), (1, 2))
    assert_neq((1, 2), (2, 1))
}

// --- arrays ---

fn test_array_literal() {
    let arr = [|1, 2, 3|]
    assert_eq(len(arr), 3)
    assert_eq(arr[0], Some(1))
    assert_eq(arr[2], Some(3))
}

fn test_array_empty() {
    let arr = [||]
    assert_eq(len(arr), 0)
}

fn test_array_single() {
    let arr = [|42|]
    assert_eq(len(arr), 1)
    assert_eq(arr[0], Some(42))
}

fn test_array_slice() {
    let arr = [|10, 20, 30, 40, 50|]
    let result = Array.slice(arr, 1, 3)
    assert_eq(len(result), 2)
    assert_eq(result[0], Some(20))
    assert_eq(result[1], Some(30))
}

fn test_array_concat() {
    let a = [|1, 2|]
    let b = [|3, 4|]
    let result = Array.concat(a, b)
    assert_eq(len(result), 4)
    assert_eq(result[0], Some(1))
    assert_eq(result[1], Some(2))
    assert_eq(result[2], Some(3))
    assert_eq(result[3], Some(4))
}

fn test_list_reverse() {
    let result = reverse([1, 2, 3])
    assert_eq(len(result), 3)
    assert_eq(first(result), 3)
    assert_eq(first(rest(result)), 2)
    assert_eq(first(rest(rest(result))), 1)
}

fn test_list_rest() {
    let result = rest([1, 2, 3])
    assert_eq(len(result), 2)
    assert_eq(first(result), 2)
    assert_eq(first(rest(result)), 3)
}

fn test_array_push() {
    let result = array_push([|1, 2|], 3)
    assert_eq(len(result), 3)
    assert_eq(result[0], Some(1))
    assert_eq(result[1], Some(2))
    assert_eq(result[2], Some(3))
}

// --- cons lists ---

fn test_list_creation() {
    let xs = list(1, 2, 3)
    assert_eq(first(xs), 1)
}

fn test_list_head_tail() {
    let xs = list(10, 20, 30)
    assert_eq(first(xs), 10)
    let tail = rest(xs)
    assert_eq(first(tail), 20)
}

fn test_list_cons_prepend() {
    let xs = list(2, 3)
    let ys = [1 | xs]
    assert_eq(first(ys), 1)
    assert_eq(first(rest(ys)), 2)
}

fn test_list_empty() {
    assert_true(is_list([]))
}

fn test_list_is_list() {
    assert_true(is_list(list(1, 2, 3)))
    assert_false(is_list([|1, 2, 3|]))
}

fn test_list_to_array() {
    let xs = list(1, 2, 3)
    let arr = to_array(xs)
    assert_eq(len(arr), 3)
    assert_eq(arr[0], Some(1))
    assert_eq(arr[1], Some(2))
    assert_eq(arr[2], Some(3))
}

fn test_list_to_list() {
    let arr = [|1, 2, 3|]
    let xs = to_list(arr)
    assert_eq(first(xs), 1)
    let back = to_array(xs)
    assert_eq(len(back), 3)
    assert_eq(back[0], Some(1))
    assert_eq(back[1], Some(2))
    assert_eq(back[2], Some(3))
}

fn test_list_contains() {
    let xs = list(1, 2, 3)
    assert_true(contains(xs, 2))
    assert_false(contains(xs, 99))
}

// --- hash maps ---

fn test_map_literal() {
    let m = {"a": 1, "b": 2}
    assert_true(Map.has(m, "a"))
    assert_true(Map.has(m, "b"))
    assert_false(Map.has(m, "c"))
}

fn test_map_get() {
    let m = Map.set({}, "x", 42)
    assert_eq(Map.get(m, "x"), Some(42))
}

fn test_map_put_overwrite() {
    let m = Map.set(Map.set({}, "x", 1), "x", 2)
    assert_eq(Map.get(m, "x"), Some(2))
}

fn test_map_delete() {
    let m = Map.set(Map.set({}, "a", 1), "b", 2)
    let m2 = Map.delete(m, "a")
    assert_false(Map.has(m2, "a"))
    assert_true(Map.has(m2, "b"))
}

fn test_map_keys_values() {
    let m = Map.set(Map.set({}, "a", 1), "b", 2)
    assert_eq(len(Map.keys(m)), 2)
    assert_eq(len(Map.values(m)), 2)
}

fn test_map_merge() {
    let a = Map.set({}, "x", 1)
    let b = Map.set({}, "y", 2)
    let merged = Map.merge(a, b)
    assert_true(Map.has(merged, "x"))
    assert_true(Map.has(merged, "y"))
}

fn test_map_immutable() {
    let m1 = Map.set({}, "a", 1)
    let m2 = Map.set(m1, "b", 2)
    assert_false(Map.has(m1, "b"))
    assert_true(Map.has(m2, "b"))
}
