define internal fastcc i64 @flux_neg(i64 %a) alwaysinline {
entry:
  %is_int = trunc i64 %a to i1
  br i1 %is_int, label %do_int, label %do_float
do_int:
  %int_result = call fastcc i64 @flux_ineg(i64 %a)
  ret i64 %int_result
