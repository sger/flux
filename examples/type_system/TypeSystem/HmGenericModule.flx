module TypeSystem.HmGenericModule {
    public fn id<T>(x: T) -> T {
        x
    }

    // Multi-param generic: both xs and elem must be the same element type.
    // T is a generic param -- convert_type_expr returns None for T, so Stage 2 applies.
    public fn prepend<T>(elem: T, xs: Array<T>) -> Array<T> {
        array_push(xs, elem)
    }
}
