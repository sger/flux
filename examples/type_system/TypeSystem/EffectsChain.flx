// root: examples/type_system

module TypeSystem.EffectsChain {
    fn io_step(x: Int) -> Int with IO {
        print("io_step=#{to_string(x)}")
        x + 1
    }

    public fn call_io_step(x: Int) -> Int with IO {
        io_step(x)
    }
}
