        drop_spec t#6 {
          unique -> reuse t#6 Node(color#7, left#8, key#9, right#10) @mask=0b0
          shared -> aether_call[owned, owned, owned, owned] Node#?[external](dup color#7
            color#7, dup left#8
            left#8, dup key#9
            key#9, dup right#10
            right#10)
        }
      _ →
        t#6

letrec rewrite_many : Tree =
