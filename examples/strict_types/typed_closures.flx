// parity: vm, llvm
// expect: success
// Typed closures with capture — passes the default static-typing checks.

fn make_adder(n: Int) -> (Int) -> Int {
    \(x: Int) -> x + n
}

fn main() with IO {
    let add5 = make_adder(5)
    let add10 = make_adder(10)
    print(add5(3))
    print(add10(3))
    print(add5(add10(1)))
}