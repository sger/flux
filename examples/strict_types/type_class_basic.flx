// Built-in type class instance declarations — parser integration test.
// This file verifies that instance declarations parse correctly
// and pass through the full pipeline (Core IR, CFG, VM).

instance Eq<Int> {
    fn eq(x, y) { x == y }
    fn neq(x, y) { x != y }
}

instance Eq<String> {
    fn eq(x, y) { x == y }
    fn neq(x, y) { x != y }
}

fn main() with IO {
    print(42)
}