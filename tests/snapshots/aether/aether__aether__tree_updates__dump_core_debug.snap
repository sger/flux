letrec set_black : Tree =
λt#1.
    case t#1 of
      Node(_, left#2, key#3, right#4) →
        reuse t#1 Node(Black#?[external], left#2, key#3, right#4) @mask=0b1
      _ →
        t#1

letrec rebuild_same : Tree =
λt#6.
    case t#6 of
      Node(color#7, left#8, key#9, right#10) →
        reuse t#6 Node(color#7, left#8, key#9, right#10) @mask=0b0
      _ →
        t#6

letrec rewrite_many : Tree =
λt#12.
    case t#12 of
      Node(_, left#13, _, _) →
        drop_spec t#12 {
          unique -> reuse t#12 Node(Black#?[external], left#13, 0, left#13)
          shared -> aether_call[owned, owned, owned, owned] Node#?[external](Black#?[external], dup left#13
            left#13, 0, left#13)
        }
      _ →
        t#12

letrec keep_or_dup_left : Tree =
λt#15, keep#16.
    case t#15 of
      Node(color#17, left#18, key#19, right#20) →
        drop_spec t#15 {
          unique -> case keep#16 of
              true →
                reuse t#15 Node(color#17, left#18, key#19, right#20) @mask=0b0
              _ →
                drop right#20
                reuse t#15 Node(color#17, left#18, key#19, left#18) @mask=0b1000
          shared -> case keep#16 of
              true →
                aether_call[owned, owned, owned, owned] Node#?[external](color#17, left#18, key#19, right#20)
              _ →
                drop right#20
                aether_call[owned, owned, owned, owned] Node#?[external](color#17, dup left#18
                left#18, key#19, left#18)
        }
      _ →
        t#15

