// parity-expected-stdout-begin
// parity-expected-stdout-end
// expect: compile_error

// E300: effect operation argument mismatch.
// `Console.read` expects `String`, but call passes `Int`.

effect Console {
    read: String -> Int
}

fn main() -> Unit with IO {
    let _ = (perform Console.read(123)) handle Console {
        read(_resume, _msg) -> 0
    }
}
