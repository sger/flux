// Custom class default method test.
// The instance provides only `eq`, and `neq` uses the class default body.

class LocalEq<a> {
    fn eq(x: a, y: a) -> Bool
    fn neq(x: a, y: a) -> Bool { !eq(x, y) }
}

instance LocalEq<Int> {
    fn eq(x, y) { x == y }
}

fn main() with IO {
    print(eq(1, 1))
    print(eq(1, 2))
    print(neq(1, 1))
    print(neq(1, 2))
}
