letrec my_map =
λxs, f.
    case xs of
      ::(h, t) →
        let %t1 = aether_call[owned] f(dup h
        h)
        let %t2 = aether_call[borrowed, borrowed] my_map(t, f)
        ::(%t1, %t2)
      _ →
        []

letrec option_map =
λopt, f.
    case opt of
      Some(x) →
        let %t3 = aether_call[owned] f(dup x
        x)
        Some(%t3)
      _ →
        None

letrec set_black =
λt.
    case t of
      Node(_, left, key, right) →
        drop_spec t {
          unique -> reuse t Node(Black, left, key, right) @mask=0b1
          shared -> aether_call[owned, owned, owned, owned] Node(Black, dup left
            left, dup key
            key, dup right
            right)
        }
      _ →
        t

letrec my_len =
λxs.
    case xs of
      ::(_, t) →
        let %t4 = aether_call[borrowed] my_len(t)
        Add(1, %t4)
      _ →
        0

letrec my_filter =
λxs, f.
    case xs of
      ::(h, t) →
        let %t5 = aether_call[owned] f(dup h
        h)
        case %t5 of
          true →
            let %t6 = aether_call[borrowed, borrowed] my_filter(t, f)
            ::(dup h
            h, %t6)
          _ →
            drop h
            aether_call[borrowed, borrowed] my_filter(t, f)
      _ →
        []

letrec my_sum =
λxs.
    case xs of
      ::(h, t) →
        let %t7 = aether_call[borrowed] my_sum(t)
        Add(h, %t7)
      _ →
        0

