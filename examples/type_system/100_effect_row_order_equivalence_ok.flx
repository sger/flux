// Effect-row concrete atom ordering is non-semantic.
// Expected: compile/run success.

fn call_swapped_effects(f: ((Int) -> Int with Time, IO), x: Int) -> Int with IO, Time {
    f(x)
}

fn add_one(x: Int) -> Int with IO, Time {
    x + 1
}

fn main() with IO, Time {
    print(to_string(call_swapped_effects(add_one, 41)))
}
