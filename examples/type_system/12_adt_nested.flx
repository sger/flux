// parity-expected-stdout-begin
// true
// false
// [|1, 3, 5, 7|]
// parity-expected-stdout-end

import Flow.Array as Array

data Tree {
    Leaf,
    Node(Tree, Int, Tree),
}

fn insert(t: Tree, v: Int) -> Tree {
    match t {
        Leaf -> Node(Leaf, v, Leaf),
        Node(left, x, right) ->
            if v < x {
                Node(insert(left, v), x, right)
            } else if v > x {
                Node(left, x, insert(right, v))
            } else {
                t
            },
    }
}

fn contains(t: Tree, v: Int) -> Bool {
    match t {
        Leaf -> false,
        Node(left, x, right) ->
            if v == x { true }
            else if v < x { contains(left, v) }
            else { contains(right, v) },
    }
}

fn inorder(t: Tree) -> Array<Int> {
    match t {
        Leaf -> [||],
        Node(left, x, right) ->
            Array.concat(inorder(left), Array.concat([|x|], inorder(right))),
    }
}

fn main() with IO, Time {
    let t = insert(insert(insert(insert(Leaf, 5), 3), 7), 1)

    print(contains(t, 3))
    print(contains(t, 4))
    print(inorder(t))
}
