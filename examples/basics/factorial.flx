// parity-expected-stdout-begin
// "Result: 120"
// parity-expected-stdout-end

fn factorial(n, acc) {
    if n == 0 {
        acc
    } else {
        factorial(n - 1, n * acc)  // Tail call!
    }
}

// Program entry point.
fn main() with IO {
    let result = factorial(5, 1)
    print("Result: " + to_string(result))
}