---
source: tests/core_to_llvm_adt_snapshots.rs
expression: render_module(&module)
---
source_filename = "flux_lir"

%FluxAdt = type {i32, i32, [0 x i64]}

%FluxTuple = type {i8, i8, i8, i8, i32, [0 x i64]}

%FluxClosure = type {ptr, i32, i32, i32, i32, [0 x i64]}

@flux.ptrtag.none = private constant i64 0

@flux.ptrtag.false = private constant i64 2

@flux.ptrtag.true = private constant i64 4

@flux.ptrtag.empty_list = private constant i64 6

@flux.ptrtag.uninit = private constant i64 8

@flux.ptrtag.yield_sentinel = private constant i64 10

@flux_arena_hp = external global ptr

@flux_arena_limit = external global ptr

@flux_idiv.div_zero_msg = private constant [16 x i8] [i8 68, i8 105, i8 118, i8 105, i8 115, i8 105, i8 111, i8 110, i8 32, i8 98, i8 121, i8 32, i8 122, i8 101, i8 114, i8 111]

@flux_imod.div_zero_msg = private constant [16 x i8] [i8 68, i8 105, i8 118, i8 105, i8 115, i8 105, i8 111, i8 110, i8 32, i8 98, i8 121, i8 32, i8 122, i8 101, i8 114, i8 111]

@flux_ctor_name.0 = private constant [5 x i8] [i8 87, i8 114, i8 97, i8 112, i8 0]

@flux_ctor_name.1 = private constant [6 x i8] [i8 69, i8 109, i8 112, i8 116, i8 121, i8 0]

declare ccc void @flux_dup(i64) nounwind

declare ccc void @flux_drop(i64) nounwind

declare ccc void @flux_gc_free(ptr) nounwind

declare ccc ptr @flux_gc_alloc(i32) nounwind

declare ccc ptr @flux_gc_alloc_header(i32, i32, i32) nounwind

declare ccc ptr @flux_bump_alloc_slow(i32, i32, i32) nounwind

declare ccc void @llvm.memset.p0.i64(ptr, i8, i64, i1) nocallback nounwind

declare ccc void @flux_panic(i64) nounwind

declare ccc i64 @flux_string_new(ptr, i32) nounwind

declare ccc i64 @flux_box_float_rt(double) nounwind

declare ccc double @flux_unbox_float_rt(i64) nounwind

define internal fastcc i64 @flux_tag_int(i64 %raw) alwaysinline {
entry:
  %shifted = shl i64 %raw, 1
  %tagged = or i64 %shifted, 1
  ret i64 %tagged
}

define internal fastcc i64 @flux_untag_int(i64 %val) alwaysinline {
entry:
  %raw = ashr i64 %val, 1
  ret i64 %raw
}

define internal fastcc i1 @flux_is_ptr(i64 %val) alwaysinline {
entry:
  %bit0 = and i64 %val, 1
  %not_int = icmp eq i64 %bit0, 0
  %above_sentinel = icmp sge i64 %val, 12
  %result = and i1 %not_int, %above_sentinel
  ret i1 %result
}

define internal fastcc ptr @flux_drop_reuse(i64 %val, i32 %size) alwaysinline {
entry:
  %is_ptr = call fastcc i1 @flux_is_ptr(i64 %val)
  br i1 %is_ptr, label %check_rc, label %not_ptr
not_ptr:
  ret ptr null
check_rc:
  %ptr = inttoptr i64 %val to ptr
  %rc_ptr = getelementptr i8, ptr %ptr, i64 -8
  %rc = load i32, ptr %rc_ptr, align 4
  %unique = icmp eq i32 %rc, 1
  br i1 %unique, label %reuse, label %fresh
reuse:
  ret ptr %ptr
fresh:
  call ccc void @flux_drop(i64 %val)
  %new_mem = call fastcc ptr @flux_bump_alloc_inline(i32 %size, i32 0, i32 0)
  ret ptr %new_mem
}

define internal fastcc i1 @flux_rc_is_unique(i64 %val) alwaysinline {
entry:
  %is_ptr = call fastcc i1 @flux_is_ptr(i64 %val)
  br i1 %is_ptr, label %check_rc, label %not_unique
check_rc:
  %ptr = inttoptr i64 %val to ptr
  %rc_ptr = getelementptr i8, ptr %ptr, i64 -8
  %rc = load i32, ptr %rc_ptr, align 4
  %is_one = icmp eq i32 %rc, 1
  ret i1 %is_one
not_unique:
  ret i1 0
}

define internal fastcc i1 @flux_is_thunk(i64 %val) alwaysinline {
entry:
  %is_ptr = call fastcc i1 @flux_is_ptr(i64 %val)
  br i1 %is_ptr, label %check_tag, label %not_thunk
check_tag:
  %ptr = inttoptr i64 %val to ptr
  %obj_tag_ptr = getelementptr i8, ptr %ptr, i64 -3
  %obj_tag = load i8, ptr %obj_tag_ptr, align 1
  %is_thunk_tag = icmp eq i8 %obj_tag, 249
  ret i1 %is_thunk_tag
not_thunk:
  ret i1 0
}

define internal fastcc i64 @flux_tag_thunk(ptr %ptr) alwaysinline {
entry:
  %tagged = ptrtoint ptr %ptr to i64
  ret i64 %tagged
}

define internal fastcc ptr @flux_untag_thunk_ptr(i64 %val) alwaysinline {
entry:
  %ptr = inttoptr i64 %val to ptr
  ret ptr %ptr
}

define internal fastcc ptr @flux_bump_alloc_inline(i32 %size, i32 %scan, i32 %tag) alwaysinline {
entry:
  %aligned = add i32 %size, 7
  %masked = and i32 %aligned, -8
  %total_i32 = add i32 %masked, 8
  %total = zext i32 %total_i32 to i64
  %hp = load ptr, ptr @flux_arena_hp, align 8
  %new_hp = getelementptr i8, ptr %hp, i64 %total
  %lim = load ptr, ptr @flux_arena_limit, align 8
  %ok = icmp ule ptr %new_hp, %lim
  br i1 %ok, label %fast, label %slow
fast:
  store ptr %new_hp, ptr @flux_arena_hp, align 8
  store i32 1, ptr %hp, align 4
  %scan8 = trunc i32 %scan to i8
  %sf_ptr = getelementptr i8, ptr %hp, i64 4
  store i8 %scan8, ptr %sf_ptr, align 1
  %tag8 = trunc i32 %tag to i8
  %ot_ptr = getelementptr i8, ptr %hp, i64 5
  store i8 %tag8, ptr %ot_ptr, align 1
  %res_ptr = getelementptr i8, ptr %hp, i64 6
  store i16 0, ptr %res_ptr, align 2
  %payload = getelementptr i8, ptr %hp, i64 8
  %aligned64 = zext i32 %masked to i64
  call ccc void @llvm.memset.p0.i64(ptr %payload, i8 0, i64 %aligned64, i1 0)
  ret ptr %payload
slow:
  %slow_ptr = call ccc ptr @flux_bump_alloc_slow(i32 %size, i32 %scan, i32 %tag)
  ret ptr %slow_ptr
}

define internal fastcc i64 @flux_iadd(i64 %a, i64 %b) alwaysinline {
entry:
  %a_raw = call fastcc i64 @flux_untag_int(i64 %a)
  %b_raw = call fastcc i64 @flux_untag_int(i64 %b)
  %result_raw = add i64 %a_raw, %b_raw
  %result = call fastcc i64 @flux_tag_int(i64 %result_raw)
  ret i64 %result
}

define internal fastcc i64 @flux_isub(i64 %a, i64 %b) alwaysinline {
entry:
  %a_raw = call fastcc i64 @flux_untag_int(i64 %a)
  %b_raw = call fastcc i64 @flux_untag_int(i64 %b)
  %result_raw = sub i64 %a_raw, %b_raw
  %result = call fastcc i64 @flux_tag_int(i64 %result_raw)
  ret i64 %result
}

define internal fastcc i64 @flux_imul(i64 %a, i64 %b) alwaysinline {
entry:
  %a_raw = call fastcc i64 @flux_untag_int(i64 %a)
  %b_raw = call fastcc i64 @flux_untag_int(i64 %b)
  %result_raw = mul i64 %a_raw, %b_raw
  %result = call fastcc i64 @flux_tag_int(i64 %result_raw)
  ret i64 %result
}

define internal fastcc i64 @flux_idiv(i64 %a, i64 %b) alwaysinline {
entry:
  %a_raw = call fastcc i64 @flux_untag_int(i64 %a)
  %b_raw = call fastcc i64 @flux_untag_int(i64 %b)
  %is_zero = icmp eq i64 %b_raw, 0
  br i1 %is_zero, label %panic, label %safe
panic:
  %msg = call ccc i64 @flux_string_new(ptr @flux_idiv.div_zero_msg, i32 16)
  call ccc void @flux_panic(i64 %msg)
  unreachable
safe:
  %result_raw = sdiv i64 %a_raw, %b_raw
  %result = call fastcc i64 @flux_tag_int(i64 %result_raw)
  ret i64 %result
}

define internal fastcc i64 @flux_imod(i64 %a, i64 %b) alwaysinline {
entry:
  %a_raw = call fastcc i64 @flux_untag_int(i64 %a)
  %b_raw = call fastcc i64 @flux_untag_int(i64 %b)
  %is_zero = icmp eq i64 %b_raw, 0
  br i1 %is_zero, label %panic, label %safe
panic:
  %msg = call ccc i64 @flux_string_new(ptr @flux_imod.div_zero_msg, i32 16)
  call ccc void @flux_panic(i64 %msg)
  unreachable
safe:
  %result_raw = srem i64 %a_raw, %b_raw
  %result = call fastcc i64 @flux_tag_int(i64 %result_raw)
  ret i64 %result
}

define internal fastcc i64 @flux_ineg(i64 %a) alwaysinline {
entry:
  %a_raw = call fastcc i64 @flux_untag_int(i64 %a)
  %neg = sub i64 0, %a_raw
  %result = call fastcc i64 @flux_tag_int(i64 %neg)
  ret i64 %result
}

define internal fastcc i64 @flux_fadd(i64 %a, i64 %b) alwaysinline {
entry:
  %a_f = call ccc double @flux_unbox_float_rt(i64 %a)
  %b_f = call ccc double @flux_unbox_float_rt(i64 %b)
  %result_f = fadd double %a_f, %b_f
  %result = call ccc i64 @flux_box_float_rt(double %result_f)
  ret i64 %result
}

define internal fastcc i64 @flux_fsub(i64 %a, i64 %b) alwaysinline {
entry:
  %a_f = call ccc double @flux_unbox_float_rt(i64 %a)
  %b_f = call ccc double @flux_unbox_float_rt(i64 %b)
  %result_f = fsub double %a_f, %b_f
  %result = call ccc i64 @flux_box_float_rt(double %result_f)
  ret i64 %result
}

define internal fastcc i64 @flux_fmul(i64 %a, i64 %b) alwaysinline {
entry:
  %a_f = call ccc double @flux_unbox_float_rt(i64 %a)
  %b_f = call ccc double @flux_unbox_float_rt(i64 %b)
  %result_f = fmul double %a_f, %b_f
  %result = call ccc i64 @flux_box_float_rt(double %result_f)
  ret i64 %result
}

define internal fastcc i64 @flux_fdiv(i64 %a, i64 %b) alwaysinline {
entry:
  %a_f = call ccc double @flux_unbox_float_rt(i64 %a)
  %b_f = call ccc double @flux_unbox_float_rt(i64 %b)
  %result_f = fdiv double %a_f, %b_f
  %result = call ccc i64 @flux_box_float_rt(double %result_f)
  ret i64 %result
}

define internal fastcc i64 @flux_fmod(i64 %a, i64 %b) alwaysinline {
entry:
  %a_f = call ccc double @flux_unbox_float_rt(i64 %a)
  %b_f = call ccc double @flux_unbox_float_rt(i64 %b)
  %result_f = frem double %a_f, %b_f
  %result = call ccc i64 @flux_box_float_rt(double %result_f)
  ret i64 %result
}

define internal fastcc i64 @flux_fneg(i64 %a) alwaysinline {
entry:
  %a_f = call ccc double @flux_unbox_float_rt(i64 %a)
  %neg = fsub double 0.0, %a_f
  %result = call ccc i64 @flux_box_float_rt(double %neg)
  ret i64 %result
}

define internal fastcc i64 @flux_not(i64 %a) alwaysinline {
entry:
  %is_false = icmp eq i64 %a, 2
  %is_none = icmp eq i64 %a, 0
  %is_empty = icmp eq i64 %a, 6
  %is_uninit = icmp eq i64 %a, 8
  %f1 = or i1 %is_false, %is_none
  %f2 = or i1 %is_empty, %is_uninit
  %is_falsy = or i1 %f1, %f2
  %result = select i1 %is_falsy, i64 4, i64 2
  ret i64 %result
}

define internal fastcc i64 @flux_and(i64 %a, i64 %b) alwaysinline {
entry:
  %a_is_true = icmp eq i64 %a, 4
  %b_is_true = icmp eq i64 %b, 4
  %combined = and i1 %a_is_true, %b_is_true
  %result = select i1 %combined, i64 4, i64 2
  ret i64 %result
}

define internal fastcc i64 @flux_or(i64 %a, i64 %b) alwaysinline {
entry:
  %a_is_true = icmp eq i64 %a, 4
  %b_is_true = icmp eq i64 %b, 4
  %combined = or i1 %a_is_true, %b_is_true
  %result = select i1 %combined, i64 4, i64 2
  ret i64 %result
}

define internal fastcc i64 @flux_add(i64 %a, i64 %b) alwaysinline {
entry:
  %is_int = trunc i64 %a to i1
  br i1 %is_int, label %do_int, label %do_float
do_int:
  %int_result = call fastcc i64 @flux_iadd(i64 %a, i64 %b)
  ret i64 %int_result
do_float:
  %float_result = call fastcc i64 @flux_fadd(i64 %a, i64 %b)
  ret i64 %float_result
}

define internal fastcc i64 @flux_sub(i64 %a, i64 %b) alwaysinline {
entry:
  %is_int = trunc i64 %a to i1
  br i1 %is_int, label %do_int, label %do_float
do_int:
  %int_result = call fastcc i64 @flux_isub(i64 %a, i64 %b)
  ret i64 %int_result
do_float:
  %float_result = call fastcc i64 @flux_fsub(i64 %a, i64 %b)
  ret i64 %float_result
}

