// root: examples/guide_type_system

module Guide.Effects {
    public fn tick_plus(x: Int) -> Int with Time {
        let _tick: Int = now_ms()
        x + 1
    }

    public fn run_with_logging(x: Int) -> Int with IO, Time {
        let value: Int = tick_plus(x)
        print("tick")
        value
    }

    public fn map_twice(f: ((Int) -> Int with |e), x: Int) -> Int with |e {
        f(f(x))
    }
}
