letrec keep_or_dup_left : Tree =
λt#15, keep#16.
    case t#15 of
      Node(color#17, left#18, key#19, right#20) →
        drop_spec t#15 {
          unique -> case keep#16 of
              true →
                reuse t#15 Node(color#17, left#18, key#19, right#20) @mask=0b0
              _ →
                drop right#20
                reuse t#15 Node(color#17, left#18, key#19, left#18) @mask=0b1000
          shared -> case keep#16 of
              true →
                aether_call[owned, owned, owned, owned] Node#?[external](dup color#17
                color#17, dup left#18
                left#18, dup key#19
                key#19, dup right#20
                right#20)
              _ →
                drop right#20
                aether_call[owned, owned, owned, owned] Node#?[external](dup color#17
                color#17, dup left#18
                left#18, dup key#19
                key#19, dup left#18
                left#18)
        }
      _ →
        t#15

