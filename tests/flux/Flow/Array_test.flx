import Flow.Array as Array

fn test_array_core_hofs() {
    assert_eq(to_string(Array.map([|1, 2, 3|], fn(x) { x * 10 })), "[|10, 20, 30|]")
    assert_eq(to_string(Array.map([||], fn(x) { x })), "[||]")
    assert_eq(to_string(Array.filter([|1, 2, 3, 4, 5|], fn(x) { x % 2 == 0 })), "[|2, 4|]")
    assert_eq(Array.fold([|1, 2, 3|], 0, fn(acc, x) { acc + x }), 6)
    assert_eq(Array.fold([||], 42, fn(acc, x) { acc + x }), 42)
    assert_eq(to_string(Array.flat_map([|1, 2, 3|], fn(x) { [|x, x * 10|] })), "[|1, 10, 2, 20, 3, 30|]")
    assert_eq(to_string(Array.flatten([|[|1, 2|], [||], [|3|]|])), "[|1, 2, 3|]")
}

fn test_array_accessors_and_predicates() {
    assert_eq(to_string(Array.first([|10, 20, 30|])), "Some(10)")
    assert_eq(to_string(Array.first([||])), "None")
    assert_eq(to_string(Array.last([|10, 20, 30|])), "Some(30)")
    assert_eq(to_string(Array.last([||])), "None")
    assert_eq(Array.length([|1, 2, 3|]), 3)
    assert_eq(Array.length([||]), 0)
    assert_eq(Array.contains([|1, 2, 3|], 2), true)
    assert_eq(Array.contains([|1, 2, 3|], 9), false)
    assert_eq(Array.contains([||], 1), false)
}

fn test_array_specific_shape() {
    let mapped = Array.map([|1, 2, 3|], fn(x) { x + 1 })
    let filtered = Array.filter([|1, 2, 3, 4|], fn(x) { x % 2 == 0 })
    let zipped = Array.zip([|1, 2|], [|10, 20|])

    assert_true(is_array(mapped))
    assert_true(is_array(filtered))
    assert_true(is_array(zipped))
    assert_eq(is_list(mapped), false)
    assert_eq(is_list(filtered), false)
    assert_eq(is_list(zipped), false)
}

fn test_array_ordering_and_slices() {
    assert_eq(to_string(Array.sort([|3, 1, 4, 1, 5|])), "[|1, 1, 3, 4, 5|]")
    assert_eq(to_string(Array.sort([||])), "[||]")
    assert_eq(to_string(Array.sort_by([|"bb", "a", "ccc"|], fn(s) { string_len(s) })), "[|\"a\", \"bb\", \"ccc\"|]")
    assert_eq(to_string(Array.reverse([|1, 2, 3|])), "[|3, 2, 1|]")
    assert_eq(to_string(Array.reverse([||])), "[||]")
    assert_eq(to_string(Array.range(0, 4)), "[|0, 1, 2, 3|]")
    assert_eq(to_string(Array.take([|1, 2, 3, 4|], 2)), "[|1, 2|]")
    assert_eq(to_string(Array.drop([|1, 2, 3, 4|], 2)), "[|3, 4|]")
}

fn test_array_zip_and_updates() {
    assert_eq(to_string(Array.zip([|1, 2, 3|], [|10, 20|])), "[|(1, 10), (2, 20)|]")
    assert_eq(to_string(Array.zip([||], [|1|])), "[||]")
    assert_eq(to_string(Array.update([|1, 2, 3|], 1, 99)), "[|1, 99, 3|]")
    assert_eq(to_string(Array.swap([|1, 2, 3|], 0, 2)), "[|3, 2, 1|]")
}
