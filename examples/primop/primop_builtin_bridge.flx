print("== PrimOp and base bridge ==");

let arr = [|10, 20, 30|];
print(array_len(arr));
print(len(arr)); // base name lowered to PrimOp::Len

let m = put({}, "lang", "flux");
print(map_get(m, "lang")); // canonical primop name
print(get(m, "lang"));     // base alias lowered to same PrimOp
print(has_key(m, "lang")); // base alias lowered to same PrimOp as map_has

print(type_of(arr));
print(is_array(arr));
print(to_string(42));
