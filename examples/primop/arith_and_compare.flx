// parity-expected-stdout-begin
// "== PrimOps: arithmetic + comparison =="
// 30
// 17
// 42
// 3.75
// 3.5
// 9
// true
// true
// true
// true
// true
// parity-expected-stdout-end

fn main() with IO {
    print("== PrimOps: arithmetic + comparison ==");

    print(iadd(10, 20));   // 30
    print(isub(20, 3));    // 17
    print(imul(6, 7));     // 42

    print(fadd(1.5, 2.25)); // 3.75
    print(fsub(5.5, 2.0));  // 3.5
    print(fmul(2.0, 4.5));  // 9.0

    print(icmp_lt(2, 3));   // true
    print(icmp_ge(10, 10)); // true
    print(fcmp_gt(2.5, 1.5)); // true
    print(cmp_eq("flux", "flux")); // true
    print(cmp_ne(1, 2)); // true
}
