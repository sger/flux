          let #4000041[synthetic]#41 = ISub(i#25, 1)
          let #4000045[synthetic]#45 = (let #4000044[synthetic]#44 = (let #4000043[synthetic]#43 = (let #4000042[synthetic]#42 = aether_call[owned] set_black#0(current#26)
          aether_call[owned] rebuild_same#5(#4000042[synthetic]#42))
          aether_call[owned] rewrite_many#11(#4000043[synthetic]#43))
          aether_call[owned, borrowed] keep_or_dup_left#14(#4000044[synthetic]#44, false))
          aether_call[owned, owned] go#24(#4000041[synthetic]#41, #4000045[synthetic]#45))
    aether_call[owned, owned] go#24(iterations#23, t#22)

