// parity: vm, llvm
// expect: success
// Tests arithmetic and comparison primops.

fn main() with IO {
    // Integer arithmetic
    print(3 + 4)
    print(10 - 3)
    print(6 * 7)
    print(15 / 4)
    print(17 % 5)
    print(-42)

    // Float arithmetic
    print(1.5 + 2.5)
    print(10.0 - 3.5)
    print(2.0 * 3.0)
    print(7.0 / 2.0)

    // Comparisons
    print(3 == 3)
    print(3 != 4)
    print(3 < 4)
    print(3 <= 3)
    print(5 > 4)
    print(5 >= 5)

    // Boolean ops
    print(true && false)
    print(true || false)
    print(!true)

    // abs / min / max
    print(abs(-7))
    print(min(3, 5))
    print(max(3, 5))
}
