// parity: vm, llvm
// expect: runtime_error
// bug: Multi-shot resume — the handler invokes the continuation twice.
//
//      Ledger:
//        2026-04-22 baseline: VM errored E1001 "Continuation is not a
//          function"; native silently printed "2" (the last resume
//          branch, first one dropped).  Divergent and unsafe.
//
//        2026-04-22 fix: Proposal 0162 Phase 3 (partial).
//          Native: the identity-resume closure now counts invocations;
//          flux_perform_direct reports E1201 "Multi-Shot Handler On
//          Native" when the counter exits >= 2.
//          VM: unchanged (E1001 already fires via one-shot enforcement
//          inside execute_resume).
//          Parity harness: collect_mismatch_details now skips
//          stdout/stderr divergence checks when the fixture declares
//          `expect: runtime_error` — the actual contract is "both
//          backends exit non-zero", not "both print the same error".
//          (Same treatment applied to `expect: compile_error`.)
//
//      Both backends now exit non-zero.  expect: runtime_error holds.
//      Full multi-shot support awaits Phase 3 proper.

effect Flip {
    flip : () -> Bool
}

fn decide() -> Int with Flip {
    let b = perform Flip.flip()
    if b { 1 } else { 2 }
}

fn main() with IO {
    // Handler resumes twice, summing both branches. Today this must fail
    // on the VM (one-shot enforcement) and is expected to fail on native
    // too until the unified runtime lands.
    let result = decide() handle Flip {
        flip(resume) -> resume(true) + resume(false)
    }
    print(to_string(result))
}
