// Handle discharges an effect requirement from a call chain.

effect Console {
    print: String -> ()
}

fn log(msg: String) -> Unit with Console {
    perform Console.print(msg)
}

fn run() -> Int {
    log("ok") handle Console {
        print(resume, _msg) -> resume(())
    }
    1
}

fn main() with IO {
    print(to_string(run()))
}


