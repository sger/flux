/*
Advent of Code - Day 2 Part 2 (Gift Shop)
Uses input file: examples/aoc/2025/aoc_day2.txt
*/

import Day2Part2 as Day2

// Program entry point.
fn main() with IO, Time {
    let content = read_file("examples/aoc/2025/aoc_day2.txt")
    let parsed_ranges = Day2.parse_ranges_text(content)
    print(Day2.solve_parsed_ranges(parsed_ranges))
}
